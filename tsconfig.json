{
  "compilerOptions": {
    "baseUrl": "src",
    "paths": {
      "~/components/*": [
        "components/*"
      ],
      "~/compounds/*": [
        "compounds/*"
      ],
      "~/sections/*": [
        "sections/*"
      ],
      "~/templates/*": [
        "templates/*"
      ],
      "~/images/icons/*": [
        "images/icons/*"
      ],
      "~/images/*": [
        "images/*"
      ],
      "~/config": [
        "config"
      ],
      "~/secret": [
        "secret"
      ],
      "~/modules/*": [
        "modules/*"
      ],
      "~/hooks/*": [
        "hooks/*"
      ]
    },
    "target": "es5",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "incremental": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx"
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "**/*.jsx",
    "**/*.js"
  ],
  "exclude": [
    "node_modules"
  ]
}
